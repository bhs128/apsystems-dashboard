# Solar EMA Monitor — Configuration
# Copy this to .env and fill in your values.
# This file is loaded by systemd (EnvironmentFile) and by ema_api_pull.py.

# === REQUIRED: APsystems EMA API credentials ===
# Get these by emailing APsystems support for OpenAPI access.
EMA_APP_ID=your_32char_app_id_here
EMA_APP_SECRET=your_12char_secret_here

# === REQUIRED: Your system identifiers ===
# Find these in the EMA portal or on your ECU.
EMA_SYSTEM_ID=your_system_id_here
EMA_ECU_ID=your_ecu_id_here

# === Weather & atmospheric data ===
# AQICN air quality token (free: https://aqicn.org/data-platform/token/)
AQICN_TOKEN=your_aqicn_token_here
AQICN_STATION=11752

# === Solcast PV forecast (free tier: 10 calls/day) ===
# Get API key at https://solcast.com/free-rooftop-solar-forecasting
SOLCAST_API_KEY=your_solcast_api_key_here
SOLCAST_SITE_ID=your_solcast_site_id_here

# === OPTIONAL: Override defaults ===
# EMA_BASE_URL=https://api.apsystemsema.com:9282
# SOLAR_DATA_DIR=/path/to/xls/csv/files   (for backfill only)

# === EZ1 micro-inverter (side panels) ===
# LAN IP of your APsystems EZ1 device (local API mode, port 8050)
EZ1_IP=your_ez1_ip_here
# EZ1_PORT=8050
